<div class="jumbotron text-center bg-white shadow-sm">
  <h1 class="display-4">Bienvenue sur The Gossip Project !</h1>
  <p class="lead">Le premier site de commérages entre moussaillons.</p>
  <a class="btn btn-primary btn-lg" href="/gossips/new/" role="button">Ajouter un potin</a>
</div>

<div class="row">
  <% gossips.each_with_index do |gossip, index| %>
    <div class="col-md-4">
      <div class="card gossip-card shadow-sm">
        <div class="card-body">
          <h5 class="card-title text-primary"><%= gossip.author %></h5>
          <p class="card-text text-truncate"><%= gossip.content %></p>
          <a href="/gossips/<%= index %>/" class="btn btn-outline-info btn-sm">Lire la suite</a>
        </div>
      </div>
    </div>
  <% end %>
</div>